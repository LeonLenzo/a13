# Pawsey Setonix project configuration
# Edit these paths before submitting any jobs

ACCOUNT="fl3"
PROJECT_DIR="/scratch/${ACCOUNT}/${USER}/a13"

# Raw reads location (upload your fastqs here before running)
RAW_READS_DIR="${PROJECT_DIR}/reads/raw"

# Reference genome: IWGSC RefSeq v2.1 (GCF_018294505.1) CDS FASTA
# Download from NCBI: GCF_018294505.1_IWGSC_CS_RefSeq_v2.1_cds_from_genomic.fna.gz
# Then: gunzip GCF_018294505.1_IWGSC_CS_RefSeq_v2.1_cds_from_genomic.fna.gz
CDS_FASTA="${PROJECT_DIR}/reference/GCF_018294505.1_IWGSC_CS_RefSeq_v2.1_cds_from_genomic.fna"
KALLISTO_INDEX="${PROJECT_DIR}/reference/GCF_018294505.1_v2.1_cds.idx"

# Output directories
FASTP_OUT="${PROJECT_DIR}/reads/trimmed"
REPAIRED_OUT="${PROJECT_DIR}/reads/repaired"
KALLISTO_OUT="${PROJECT_DIR}/kallisto_quant"

# Adapter file (relative to scripts — copied into repo)
ADAPTERS="${PROJECT_DIR}/qc/adapters.fa"

# Sample list
SAMPLES="${PROJECT_DIR}/config/samples.txt"
